# amd-rocm-ollama: per-host overrides for docker-compose.yml.
# Copy to `.env` and edit. `.env` is gitignored.
#
# All variables are optional; defaults in docker-compose.yml match Ubuntu 24.04
# on the test box (Strix Halo / Radeon 8060S).

# Numeric GIDs for /dev/kfd and /dev/dri access. Read from the HOST:
#   VIDEO_GID=$(getent group video  | cut -d: -f3)
#   RENDER_GID=$(getent group render | cut -d: -f3)
VIDEO_GID=44
RENDER_GID=992

# Path on the HOST to the Ollama model store, bind-mounted into the container
# at /root/.ollama. Default matches Ubuntu's bundled ollama package.
OLLAMA_MODEL_STORE=/usr/share/ollama/.ollama

# Verbosity of the Ollama server log. 0 = quiet, 1 = normal, 2 = debug.
# Useful while bringing the stack up; lower it once healthy.
OLLAMA_DEBUG=2
