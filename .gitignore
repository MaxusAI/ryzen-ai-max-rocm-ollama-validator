# NOTE: .gitmodules MUST be tracked - do not add it here.

# Editor / OS junk
.DS_Store
.idea/
.vscode/
*.swp
*~

# Local build/cache scratch dirs
build/
dist/
.cache/
.ccache/
__pycache__/

# docker-compose override conventions (per-developer local tweaks)
docker-compose.override.yml
docker-compose.local.yml

# Local env files (avoid leaking secrets). .env.example is tracked as a
# template (host-specific GIDs and model store path); .env is per-machine.
.env
.env.*
!.env.example

# Per-machine runtime artifacts from log-run.sh / validate.sh / stress-test.sh.
# The JSONL records embed host-specific data (hostname, kernel, MES firmware,
# loaded models, VRAM split). Track per-machine, do not share via git.
logs/
